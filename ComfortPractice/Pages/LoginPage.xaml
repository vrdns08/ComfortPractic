<Page x:Class="ComfortPractice.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComfortPractice.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="AUTO"/>
            <RowDefinition Height="AUTO"/>
            <RowDefinition Height="AUTO"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Вход" Grid.Column="1" Grid.Row="0" FontSize="24"  HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Candara" FontWeight="Black" Margin="0 50 0 30"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0 0 0 20">
            <TextBlock Text="Логин" FontSize="18"/>
            <TextBox x:Name="Login" Height="50" FontSize="18" Padding="10" Width="290"/>
            <TextBlock Text="" FontSize="18"/>
            <TextBlock Text="Пароль" FontSize="18"/>
            <PasswordBox x:Name="password" Height="50" FontSize="16" Padding="10" Width="300" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1">
            <Button x:Name="enter" Content="Вход" Height="50" Margin="0 0 0 10" Click="enter_Click" FontWeight="Bold" BorderThickness="1" />
            <Button x:Name="registration" Background="White" Foreground="#355CBD" Content="Регистрация" FontWeight="Bold" Height="50" BorderThickness="1" Margin="0 0 0 10" BorderBrush="#355CBD" Click="registration_Click"/>
        </StackPanel>
    </Grid>
</Page>
