<Page x:Class="ComfortPractice.Pages.SalesHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComfortPractice.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
      Title="SalesHistoryPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#D2DFFF" Padding="10">
            <StackPanel>
                <TextBlock x:Name="PartnerNameTb" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TotalSalesTb" FontSize="16" HorizontalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="FilteredTotalTb" FontSize="14" HorizontalAlignment="Center" Margin="5" Foreground="#355CBD"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="Дата с:" VerticalAlignment="Center"/>
            <DatePicker x:Name="StartDatePicker" Width="100" Margin="5"/>
            <TextBlock Text="по:" VerticalAlignment="Center"/>
            <DatePicker x:Name="EndDatePicker" Width="100" Margin="5"/>
            <Button x:Name="FilterBtn" Content="Применить" Click="FilterBtn_Click"/>
            <Button x:Name="ResetBtn" Content="Сбросить" Click="ResetBtn_Click"/>
        </StackPanel>

        <ListView x:Name="SalesLW" Grid.Row="2" Margin="10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Дата" Width="130" DisplayMemberBinding="{Binding RequestDate, StringFormat=dd.MM.yyyy}"/>
                    <GridViewColumn Header="Продукция" Width="600" DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Количество" Width="120" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Сумма" Width="150" DisplayMemberBinding="{Binding TotalAmount, StringFormat={}{0:N2} руб.}"/>
                    <GridViewColumn Header="Статус" Width="130" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button x:Name="BackBtn" Grid.Row="3" Content="Назад" Width="100" Height="35" HorizontalAlignment="Center" Margin="10" Click="BackBtn_Click"/>
    </Grid>
</Page>